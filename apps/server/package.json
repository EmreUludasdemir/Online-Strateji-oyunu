{
  "name": "@frontier/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "corepack pnpm --filter @frontier/shared build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx tests/setupTestDb.ts && vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "alpha:provision": "tsx prisma/provisionAlphaUsers.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@frontier/shared": "workspace:*",
    "@prisma/client": "6.18.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "prisma": "6.18.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

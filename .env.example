DATABASE_URL="postgresql://postgres:postgres@localhost:5433/frontier_dominion?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/frontier_dominion?schema=test"
JWT_SECRET="replace-this-with-a-long-secret"
PORT=3101
LAUNCH_PHASE=closed_alpha
REGISTRATION_MODE=login_only
STORE_ENABLED=false
SESSION_TTL_SECONDS=604800
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_MAX=15
AUTH_RATE_LIMIT_WINDOW_MS=60000
COMMAND_RATE_LIMIT_MAX=30
COMMAND_RATE_LIMIT_WINDOW_MS=60000
OPS_METRICS_TOKEN=
# Realtime adapter: in_memory (single instance) or redis (multi-instance)
REALTIME_ADAPTER=in_memory
# Redis URL for multi-instance realtime support (required when REALTIME_ADAPTER=redis)
REDIS_URL=redis://localhost:6379
# Production security settings (required in production)
ALLOWED_ORIGINS=
TRUST_PROXY=false
GRACEFUL_SHUTDOWN_TIMEOUT_MS=30000
